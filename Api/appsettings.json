{
  "AllowedHosts": "*",
  "AppName": "OrderProcessor",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.Grafana.Loki"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProcessId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Level:u3} - {Timestamp:HH:mm:ss}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki:3100",
          "labels": [
            {
              "key": "application",
              "value": "OrderProcessor"
            },
            {
              "key": "environment",
              "value": "Production"
            }
          ]
        }
      }
    ]
  },
  "Database": {
    "ConnectionString": "Server=localhost;Database=MyDatabase;User Id=myuser;Password=mypassword;"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topic": "my-topic"
  }
}
